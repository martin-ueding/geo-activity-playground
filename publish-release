#!/usr/bin/env python3
"""Idempotent release script for geo-activity-playground."""

import json
import os
import subprocess
import tomllib
import urllib.error
import urllib.request
from datetime import date
from pathlib import Path

import mastodon

REPO_ROOT = Path(__file__).parent
CHANGELOG = REPO_ROOT / "docs/changelog.md"
PYPROJECT = REPO_ROOT / "pyproject.toml"
PYPI_PROJECT = "geo-activity-playground"
NEXT_VERSION_MARKER = "<!-- next version below this line -->"


def run(*args: str) -> None:
    subprocess.run(args, check=True, cwd=REPO_ROOT)


def capture(*args: str) -> str:
    result = subprocess.run(
        args, check=True, capture_output=True, text=True, cwd=REPO_ROOT
    )
    return result.stdout.strip()


def step(label: str) -> None:
    print(f"\n=== {label} ===")


def determine_next_version() -> str:
    step("Determine next version")
    try:
        version = capture("uv", "run", "cz", "bump", "--get-next")
        print(f"Next version: {version}")
    except subprocess.CalledProcessError:
        version = capture("uv", "version", "--short")
    return version


def set_pyproject_version(version: str) -> None:
    step("Set version in pyproject.toml")
    with open(PYPROJECT, "rb") as f:
        current_version = tomllib.load(f)["project"]["version"]
    if current_version != version:
        run("uv", "version", version)
    else:
        print(f"[skip] already at {version}")


def update_changelog_header(version: str) -> None:
    step("Update changelog header")
    changelog_text = CHANGELOG.read_text()
    version_header = f"## Version {version}"
    if version_header not in changelog_text:
        today = date.today().isoformat()
        CHANGELOG.write_text(
            changelog_text.replace(
                "## Unreleased", f"## Version {version} — {today}", 1
            )
        )
    else:
        print(f"[skip] {version_header} already present")


def commit_version_bump(version: str) -> None:
    step("Commit version bump")
    bump_msg = f"chore: bump version to {version}"
    if not capture("git", "log", "--oneline", "--grep", bump_msg):
        if capture("git", "status", "--porcelain"):
            run("git", "commit", "-a", "-m", bump_msg)
        else:
            print("[skip] nothing to commit")
    else:
        print("[skip] bump commit already in log")


def create_git_tag(version: str) -> None:
    step("Create git tag")
    if not capture("git", "tag", "-l", version):
        run("git", "tag", version)
    else:
        print(f"[skip] tag {version} already exists")


def push_commits_and_tags() -> None:
    step("Push commits and tags")
    run("git", "push")
    run("git", "push", "--tags")


def build_wheel() -> None:
    step("Build wheel")
    run("uv", "build")


def publish_to_pypi(version: str) -> None:
    step("Publish to PyPI")
    already_published = False
    try:
        with urllib.request.urlopen(
            f"https://pypi.org/pypi/{PYPI_PROJECT}/json"
        ) as resp:
            data = json.load(resp)
        already_published = bool(data.get("releases", {}).get(version))
    except urllib.error.HTTPError as e:
        if e.code != 404:
            raise
    if already_published:
        print(f"[skip] {version} already on PyPI")
    else:
        run(
            "uv",
            "publish",
            "--token",
            os.environ["PYPI_TOKEN_GEO_ACTIVITY_PLAYGROUND"],
            f"dist/geo_activity_playground-{version}-py3-none-any.whl",
        )


def create_github_release(version: str) -> None:
    step("Create GitHub release")
    gh_check = subprocess.run(
        ["gh", "release", "view", version],
        capture_output=True,
        cwd=REPO_ROOT,
    )
    if gh_check.returncode != 0:
        notes = capture(
            "uv", "run", "python3", "extract-changelog.py", str(CHANGELOG), version
        )
        run("gh", "release", "create", version, "--notes", notes, "--title", version)
    else:
        print(f"[skip] GitHub release {version} already exists")


def post_to_mastodon(version: str) -> None:
    step("Post to Mastodon")

    today = date.today().isoformat()
    anchor = f"version-{version.replace('.', '-')}-%E2%80%94-{today}"
    changelog_url = f"https://martin-ueding.github.io/geo-activity-playground/changelog.html#{anchor}"

    text = (
        f"Version {version} von #GeoActivityPlayground ist nun verfügbar!\n\n"
        f"Alle Änderungen im Changelog:\n{changelog_url}"
    )

    ctl_toml = Path.home() / "Projekte/eigene-webseite/ctl.toml"
    if ctl_toml.exists():
        with open(ctl_toml, "rb") as f:
            config = tomllib.load(f)
        mastodon_config = config["mastodon"]

        client = mastodon.Mastodon(
            api_base_url=mastodon_config["url"],
            client_id=mastodon_config["client_id"],
            client_secret=mastodon_config["client_secret"],
            access_token=mastodon_config["access_token"],
        )
        result = client.status_post(text, visibility="public")
        print(f"Posted: {result['url']}")
    else:
        print("[skip] ctl.toml not found; post this manually:")
        print(text)


def restore_unreleased_section() -> None:
    step("Restore Unreleased section in changelog")
    changelog_text = CHANGELOG.read_text()
    if "## Unreleased" not in changelog_text:
        CHANGELOG.write_text(
            changelog_text.replace(
                NEXT_VERSION_MARKER,
                f"{NEXT_VERSION_MARKER}\n\n## Unreleased\n",
                1,
            )
        )
    else:
        print("[skip] ## Unreleased already present")


def commit_and_push_changelog_restore() -> None:
    step("Commit and push changelog restore")
    final_msg = "docs: add unreleased section to changelog"
    if capture("git", "status", "--porcelain"):
        run("git", "commit", "-a", "-m", final_msg)
    else:
        print("[skip] nothing to commit")
    run("git", "push")


def main() -> None:
    version = determine_next_version()
    set_pyproject_version(version)
    update_changelog_header(version)
    commit_version_bump(version)
    create_git_tag(version)
    push_commits_and_tags()
    build_wheel()
    publish_to_pypi(version)
    create_github_release(version)
    post_to_mastodon(version)
    restore_unreleased_section()
    commit_and_push_changelog_restore()
    print("\nRelease complete.")


if __name__ == "__main__":
    main()

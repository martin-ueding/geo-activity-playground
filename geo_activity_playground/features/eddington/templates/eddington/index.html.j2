{% extends "page.html.j2" %}

{% block container %}
<h1 class="mb-3">{{ _('Eddington Number for %(display_name)s', display_name=display_name) }}</h1>

<div class="mb-3">
    {% include "search_form.html.j2" %}
</div>

<div class="row mb-3">
    <div class="col-md-4">
        {% if divisor_values_avail | length > 1 %}
        <form method="GET">
            <div class="mb-3">
                <label class="form-label">{{ _('Divisor') }}</label>
                <select class="form-select" aria-label="Divisor" name="eddington_divisor" onchange="this.form.submit()">
                    {% for dv in divisor_values_avail %}
                    <option {% if dv==eddington_divisor %} selected {% endif %}>{{ dv }}</option>
                    {% endfor %}
                    {% for key, value in query.items() %}
                        {% if value and key != "active" %}
                            {% if value is string %}
                                <input type="hidden" name="{{ key }}" value="{{ value }}"/>
                            {% else %}
                                {% for v in value %}
                                <input type="hidden" name="{{ key }}" value="{{ v }}"/>
                                {% endfor %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
        </form>
        {% endif %}

        <h2>{{ _('Definition') }}</h2>

        <p>{{ _('Your Eddington number is') }} <b>{{ eddington_number }}</b>.</p>

        <p>{{ _('That means that on %(eddington_number)s separate days you have recorded activities with a %(display_name)s exceeding %(eddington_number)s %(unit)s.', eddington_number=eddington_number, display_name=display_name, unit=unit) }} {{ _('Achieving a high %(display_name)s is one thing, doing so often is another. But doing so often is hard. Also if you increment the Eddington number, all days with a lower %(display_name)s will not count any more. It becomes increasingly hard to increment the Eddington number because you don\'t only need to achieve a higher count, but all lesser activities don\'t count towards the bigger number.', display_name=display_name) }}
        </p>
    </div>

    <div class="col-md-8">
        <h2>{{ _('Missing days') }}</h2>

        <p>{{ _('How many more days do you need to increment your Eddington number?') }}</p>

        <table class="table">
            <thead>
                <tr>
                    <th>{{ display_name }} / {{ unit }}</th>
                    <th>{{ _('Count') }}</th>
                    <th>{{ _('Missing days') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in eddington_table %}
                <tr>
                    <td>{{ row[column_name] }}</td>
                    <td>{{ row['total'] }}</td>
                    <td>{{ row['missing'] }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="row mb-1">
    <div class="col">
        <h2>{{ _('Plot') }}</h2>

        <p>{{ _('In a graphical representation, the Eddington number is the %(display_name)s where the red line intersects with the blue area.', display_name=display_name) }}</p>

        {{ vega_direct(logarithmic_plot) }}
    </div>
</div>

<div class="mb-3">
    <h2 class="mb-3">{{ _('Eddington number history') }}</h2>

    <p>{{ _('How did the Eddington number evolve over time?') }}</p>

    {{ vega_direct(eddington_number_history_plot) }}
</div>

<div class="mb-3">
    <h2 class="mb-3">{{ _('Yearly Eddington number') }}</h2>

    <p>{{ _('If we only consider the activities within one calendar year for the Eddington number, we get the following:') }}</p>

    <table class="table">
        <thead>
            <tr>
                <th>{{ _('Year') }}</th>
                <th>{{ _('Eddington number') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for year, eddington in yearly_eddington.items() %}
            <tr>
                <td>{{ year }}</td>
                <td>{{ eddington }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>


<h2 class="mb-3">{{ _('Eddington number per Week') }}</h2>

<div class="row mb-3">
    <div class="col-md-8">
        {{ vega_direct(eddington_per_week_plot) }}
    </div>

    <div class="col-md-4">
        <table class="table">
            <thead>
                <tr>
                    <th>{{ display_name }} / {{ unit }}</th>
                    <th>{{ _('Count') }}</th>
                    <th>{{ _('Missing weeks') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for row in eddington_table_weeks %}
                <tr>
                    <td>{{ row[column_name] }}</td>
                    <td>{{ row['total'] }}</td>
                    <td>{{ row['missing'] }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

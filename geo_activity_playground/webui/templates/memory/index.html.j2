{% extends "page.html.j2" %}

{% block container %}
<h1>{{ _('Memory Inspector') }}</h1>
<p class="text-muted">{{ _('PID') }}: {{ pid }} — {{ _('data reflects only this worker process') }}</p>

<h2>{{ _('Process Memory') }}</h2>
{% if proc_memory %}
<table class="table table-sm table-bordered w-auto">
    <thead><tr><th>{{ _('Field') }}</th><th>{{ _('MiB') }}</th></tr></thead>
    <tbody>
    {% for key, value in proc_memory.items() %}
        <tr><td><code>{{ key }}</code></td><td class="text-end">{{ value }}</td></tr>
    {% endfor %}
    </tbody>
</table>
{% else %}
<p class="text-muted">{{ _('/proc not available') }}</p>
{% endif %}

<h2>{{ _('Function Cache Sizes') }}</h2>
<table class="table table-sm table-bordered">
    <thead>
        <tr>
            <th>{{ _('Function') }}</th>
            <th class="text-end">{{ _('hits') }}</th>
            <th class="text-end">{{ _('misses') }}</th>
            <th class="text-end">{{ _('currsize') }}</th>
            <th class="text-end">{{ _('maxsize') }}</th>
        </tr>
    </thead>
    <tbody>
    {% for row in cache_infos %}
        <tr>
            <td><code>{{ row.name }}</code></td>
            <td class="text-end">{{ row.hits }}</td>
            <td class="text-end">{{ row.misses }}</td>
            <td class="text-end">{{ row.currsize }}</td>
            <td class="text-end">{{ row.maxsize if row.maxsize is not none else '∞' }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<h2>{{ _('Top Allocations (tracemalloc)') }}</h2>
{% if tracemalloc_active %}
    <form action="{{ url_for('memory.stop_tracemalloc') }}" method="POST" class="mb-3">
        <button type="submit" class="btn btn-warning btn-sm">{{ _('Stop tracing') }}</button>
    </form>
    {% if top_allocations %}
    <table class="table table-sm table-bordered table-hover">
        <thead>
            <tr>
                <th>{{ _('File') }}</th>
                <th class="text-end">{{ _('Line') }}</th>
                <th>{{ _('Code') }}</th>
                <th class="text-end">{{ _('MiB') }}</th>
                <th class="text-end">{{ _('Objects') }}</th>
            </tr>
        </thead>
        <tbody>
        {% for row in top_allocations %}
            <tr>
                <td><small class="text-muted">{{ row.file }}</small></td>
                <td class="text-end">{{ row.lineno }}</td>
                <td><code>{{ row.line }}</code></td>
                <td class="text-end">{{ row.size_mib }}</td>
                <td class="text-end">{{ row.count }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p class="text-muted">{{ _('No allocation data yet — tracing just started.') }}</p>
    {% endif %}
{% else %}
    <p>{{ _('tracemalloc is not active. Start it to capture per-line allocation data. Note: this adds overhead to every allocation.') }}</p>
    <form action="{{ url_for('memory.start_tracemalloc') }}" method="POST">
        <button type="submit" class="btn btn-primary btn-sm">{{ _('Start tracing') }}</button>
    </form>
{% endif %}
{% endblock %}

{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">{{ _('Technical Maintenance') }}</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">{{ _('Technical Maintenance') }}</h1>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Explorer Tiles') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Sometimes the tile visit state gets corrupted and needs to be re-indexed. This will clear the current tile visit cache and re-scan all activities to rebuild it.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to reset the tile visit state? This can take a while depending on the number of activities.') }}');">
            <input type="hidden" name="action" value="reset_tile_visit_state">
            <button type="submit" class="btn btn-warning">
                {{ _('Reset tile visit state') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Re-enrich All Activities') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Re-runs enrichment on all activities using their raw time series data. Use this to apply updated processing logic (such as GPS spike filtering) to existing activities.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to re-enrich all activities? This can take a while depending on the number of activities.') }}');">
            <input type="hidden" name="action" value="reenrich_all_activities">
            <button type="submit" class="btn btn-warning">
                {{ _('Re-enrich all activities') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Activity Data Repair') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Repairs all activities by re-running enrichment on raw time series data. Use this when activity trimming, share picture rendering, or map data has become inconsistent after previous processing errors.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to repair all activities? This can take a while depending on the number of activities.') }}');">
            <input type="hidden" name="action" value="repair_activities">
            <button type="submit" class="btn btn-warning">
                {{ _('Repair activities') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Refresh Strava Activity Names') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Fetches activity summaries from Strava with paginated API calls and updates local activity names by matching upstream IDs. This keeps Strava as the source of truth for activity titles without re-importing everything.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to refresh activity names from Strava? This can take a while depending on the number of activities.') }}');">
            <input type="hidden" name="action" value="refresh_strava_activity_names">
            <button type="submit" class="btn btn-warning">
                {{ _('Refresh activity names from Strava') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Re-import Time Series from Activity Files') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Re-reads the raw time series data from the original activity files (GPX, FIT, TCX, …) for all activities that were imported from local files. Existing metadata (name, equipment, kind, tags) is preserved. Use this to pick up parser improvements or to recover from a corrupted parquet cache.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to re-import time series from activity files? This can take a while depending on the number of activities.') }}');">
            <input type="hidden" name="action" value="reimport_time_series_from_files">
            <button type="submit" class="btn btn-warning">
                {{ _('Re-import time series from files') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-warning mb-3">
    <div class="card-header bg-warning text-dark">
        <h5 class="card-title mb-0">{{ _('Time Zone Fixer') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('Prior to version 1.3.0, activity times were interpreted in the local time zone. Use these actions to reinterpret already-imported activity timestamps.') }}
        </p>
        <p class="card-text">
            {{ _('Your activities are shown in the local time zone but the times look wrong (all off by your UTC offset):') }}
        </p>
        <form method="POST" class="mb-3" onsubmit="return confirm('{{ _('Are you sure you want to reinterpret all activity times as local timezone and convert to UTC?') }}');">
            <input type="hidden" name="action" value="fix_timezone_local_to_utc">
            <button type="submit" class="btn btn-warning">
                {{ _('Interpret times as local time zone') }}
            </button>
        </form>
        <p class="card-text">
            {{ _('Your activities seem to be UTC but times appear off — re-apply timezone from coordinates:') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to re-apply UTC timezone to all activities?') }}');">
            <input type="hidden" name="action" value="fix_timezone_utc_to_utc">
            <button type="submit" class="btn btn-warning">
                {{ _('Interpret times as UTC') }}
            </button>
        </form>
    </div>
</div>

<div class="card border-danger mb-3">
    <div class="card-header bg-danger text-white">
        <h5 class="card-title mb-0">{{ _('Wipe Local Activity State') }}</h5>
    </div>
    <div class="card-body">
        <p class="card-text">
            {{ _('This deletes all imported activities and related local state. It truncates most database tables, clears the Cache, Time Series, and Photos directories, and resets Strava sync progress. Equipment, kinds, and Strava API credentials are preserved.') }}
        </p>
        <form method="POST" onsubmit="return confirm('{{ _('Are you sure you want to wipe local activity state? This cannot be undone.') }}');">
            <input type="hidden" name="action" value="wipe_local_state">
            <button type="submit" class="btn btn-danger">
                {{ _('Wipe local activity state') }}
            </button>
        </form>
    </div>
</div>
{% endblock %}

{% extends "page.html.j2" %}
{% from "plot-macros.html.j2" import vega_direct %}

{% block container %}
<h1 class="mb-3">{{ _("Filter Playground") }}: {{ activity.name }}</h1>

{% if initial_data is none %}
<div class="alert alert-warning">{{ _("This activity has no GPS data.") }}</div>
{% else %}

<div class="row mb-3">
    {# Parameter panel #}
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">{{ _("Kalman Filter Parameters") }}</div>
            <div class="card-body">

                <div class="mb-3">
                    <label for="sigma-gps" class="form-label">
                        {{ _("GPS noise σ") }} (<span id="sigma-gps-val">{{ defaults.sigma_gps }}</span> m)
                    </label>
                    <input type="range" class="form-range filter-param" id="sigma-gps"
                           min="1" max="100" step="1" value="{{ defaults.sigma_gps }}">
                    <small class="text-muted">{{ _("Typical consumer GPS: 5–20 m") }}</small>
                </div>

                <div class="mb-3">
                    <label for="sigma-process" class="form-label">
                        {{ _("Process noise σ") }} (<span id="sigma-process-val">{{ defaults.sigma_process }}</span> m/s²)
                    </label>
                    <input type="range" class="form-range filter-param" id="sigma-process"
                           min="0.1" max="20" step="0.1" value="{{ defaults.sigma_process }}">
                    <small class="text-muted">{{ _("Max plausible acceleration") }}</small>
                </div>

                <div class="mb-3">
                    <label for="gate-chi2" class="form-label">
                        {{ _("Gate threshold χ²") }} (<span id="gate-chi2-val">{{ defaults.gate_chi2 }}</span>)
                    </label>
                    <input type="range" class="form-range filter-param" id="gate-chi2"
                           min="1" max="30" step="0.1" value="{{ defaults.gate_chi2 }}">
                    <small class="text-muted">95% = 5.99 &middot; 99% = 9.21 &middot; 99.9% = 13.82</small>
                </div>

                <div id="exclusion-summary" class="alert alert-info py-2 small">
                    {{ _("Excluded: %(n)s / %(total)s points", n=initial_data.excluded_count, total=initial_data.total_count) }}
                </div>

            </div>
        </div>
    </div>

    {# Map #}
    <div class="col-md-9">
        <div id="filter-playground-map" style="height: 450px;" class="mb-2"></div>
        <div class="d-flex gap-3 small text-muted">
            <span><span style="display:inline-block;width:20px;height:3px;background:#6699cc;vertical-align:middle"></span> {{ _("Original") }}</span>
            <span><span style="display:inline-block;width:20px;height:3px;background:#22aa44;vertical-align:middle"></span> {{ _("Filtered") }}</span>
            <span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#cc2222;display:inline-block;vertical-align:middle"></span> {{ _("Excluded points") }}</span>
        </div>
    </div>
</div>

{# Speed plot #}
<div id="speed-plot" class="mb-4"></div>

<script>
const activityId = {{ activity.id }};
const originalGeojson = {{ original_geojson|safe }};
const initialData = {{ initial_data|tojson }};

// Map setup
const map = L.map('filter-playground-map', { fullscreenControl: true });
L.tileLayer('/tile/pastel/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '{{ map_tile_attribution|safe }}'
}).addTo(map);

const originalLayer = L.geoJSON(originalGeojson, {
    style: { color: '#6699cc', weight: 2, opacity: 0.7 }
}).addTo(map);
if (originalLayer.getBounds().isValid()) {
    map.fitBounds(originalLayer.getBounds());
}

const filteredLayer = L.layerGroup().addTo(map);
const excludedLayer = L.layerGroup().addTo(map);

function applyData(data) {
    filteredLayer.clearLayers();
    L.geoJSON(JSON.parse(data.filtered_geojson), {
        style: { color: '#22aa44', weight: 3, opacity: 0.9 }
    }).addTo(filteredLayer);

    excludedLayer.clearLayers();
    L.geoJSON(JSON.parse(data.excluded_geojson), {
        pointToLayer: (feature, latlng) =>
            L.circleMarker(latlng, {
                radius: 5, color: '#cc2222', fillColor: '#cc2222',
                fillOpacity: 0.8, weight: 1
            })
    }).addTo(excludedLayer);

    vegaEmbed('#speed-plot', data.speed_plot, { actions: false }).catch(console.error);

    document.getElementById('exclusion-summary').textContent =
        `{{ _("Excluded:") }} ${data.excluded_count} / ${data.total_count} {{ _("points") }}`;
}

applyData(initialData);

// Slider live-value display
document.getElementById('sigma-gps').addEventListener('input', e => {
    document.getElementById('sigma-gps-val').textContent = e.target.value;
});
document.getElementById('sigma-process').addEventListener('input', e => {
    document.getElementById('sigma-process-val').textContent = e.target.value;
});
document.getElementById('gate-chi2').addEventListener('input', e => {
    document.getElementById('gate-chi2-val').textContent = e.target.value;
});

// Debounced fetch on any slider change
let debounceTimer;
document.querySelectorAll('.filter-param').forEach(el => {
    el.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            const params = new URLSearchParams({
                sigma_gps: document.getElementById('sigma-gps').value,
                sigma_process: document.getElementById('sigma-process').value,
                gate_chi2: document.getElementById('gate-chi2').value,
            });
            fetch(`/filter-playground/${activityId}/compute?${params}`)
                .then(r => r.json())
                .then(applyData)
                .catch(console.error);
        }, 350);
    });
});
</script>

{% endif %}
{% endblock %}

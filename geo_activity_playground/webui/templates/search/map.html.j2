{% extends "page.html.j2" %}

{% block container %}

<h1 class="row mb-3">{{ _('Activities Overview & Search (Map)') }}</h1>

<div class="mb-3">
    {% include "search_form.html.j2" %}
</div>

<p class="mb-2">
    <a href="{{ url_for('search.index') }}?{{ base_query_str }}">{{ _('Table view') }}</a>
</p>

<div class="row row-cols-1 row-cols-md-4 g-3 mb-3">
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Activities') }}</div>
                <div class="fs-4 fw-semibold">{{ total }}</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total distance') }}</div>
                <div class="fs-4 fw-semibold">{{ '%.1f'|format(total_distance_km) }} km</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total elevation gain') }}</div>
                <div class="fs-4 fw-semibold">{{ '%.0f'|format(total_elevation_gain_m) }} m</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total elapsed time') }}</div>
                <div class="fs-4 fw-semibold">{{ total_elapsed_time|td }}</div>
            </div>
        </div>
    </div>
</div>

{% if aggregate_map_count > 0 %}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-2">{{ _('Aggregate map overview') }}</h2>
        <p class="text-body-secondary mb-3">
            {{ _('Showing latest') }} {{ aggregate_map_count }} {{ _('activities on one map.') }}
        </p>
        <div id="map-aggregate" style="height: 360px; width: 100%;"></div>
    </div>
</div>
{% endif %}

<script>
    function add_map(id, geojson, options = {}) {
        let map = L.map(`map-${id}`, {
            fullscreenControl: true
        })
        L.tileLayer('/tile/color/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '{{ map_tile_attribution|safe }}'
        }).addTo(map)

        let geojson_layer = L.geoJSON(geojson, {
            style: feature => {
                if (feature?.geometry?.type === "LineString") {
                    return {
                        color: feature?.properties?.color || "#3388ff",
                        weight: options.weight || 4,
                        opacity: options.opacity || 1
                    };
                }
                return {};
            },
            pointToLayer: (feature, latlng) => {
                const progress = feature?.properties?.marker_progress;
                if (Number.isFinite(progress)) {
                    return L.marker(latlng, {
                        icon: window.progressMarkerIcon(progress)
                    });
                }
                return L.circleMarker(latlng);
            }
        }).addTo(map)
        if (geojson_layer.getLayers().length > 0) {
            map.fitBounds(geojson_layer.getBounds(), { padding: [10, 10] })
        }
        return map
    }
</script>

{% if aggregate_map_count > 0 %}
<script>
    fetch("{{ url_for('search.map_aggregate_geojson') }}?{{ base_query_str }}")
        .then(response => response.json())
        .then(geojson => {
            add_map("aggregate", geojson, { weight: 3, opacity: 0.8 });
        });
</script>
{% endif %}

{% if activities_page %}
{% for activity_batch in activities_page|batch(3) %}
<div class="row row-cols-1 row-cols-md-3 g-4 mb-3">
    {% for index, activity in activity_batch %}
    <div class="col">
        <div class="card">
            <div class="card-img-top" id="map-{{ activity['id'] }}" style="height: 200px; width: 100%;"></div>
            <script>
                fetch("/activity/{{ activity['id'] }}/line.geojson").then(response => response.json()).then(
                    geojson => {
                        add_map("{{ activity['id'] }}", geojson);
                    }
                )
            </script>
            <div class="card-body">
                <a href="{{ url_for('activity.show', id=activity['id']) }}">
                    <h5 class="card-title">{{ activity['name'] }}</h5>
                </a>
                <p class="card-text">{{ activity['equipment'] }} · {{ activity['kind'] }}</p>
                {% if activity['start_local'] is defined and not activity['start_local']|isna %}
                <p class="card-text"><small class="text-body-secondary">{{ activity['start_local']|dt }} {{ activity['iana_timezone'] }}</small></p>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endfor %}

{% if total_pages > 1 %}
<nav aria-label="{{ _('Pagination') }}" class="mt-3">
    <ul class="pagination justify-content-center flex-wrap">
        <li class="page-item {{ 'disabled' if page <= 1 }}">
            <a class="page-link" href="?{% if base_query_str %}{{ base_query_str }}&{% endif %}page={{ page - 1 }}" {{ 'aria-disabled=true' if page <= 1 }}>{{ _('Previous') }}</a>
        </li>
        {% for p in range(1, total_pages + 1) %}
        <li class="page-item {{ 'active' if p == page }}">
            <a class="page-link" href="?{% if base_query_str %}{{ base_query_str }}&{% endif %}page={{ p }}">{{ p }}</a>
        </li>
        {% endfor %}
        <li class="page-item {{ 'disabled' if page >= total_pages }}">
            <a class="page-link" href="?{% if base_query_str %}{{ base_query_str }}&{% endif %}page={{ page + 1 }}" {{ 'aria-disabled=true' if page >= total_pages }}>{{ _('Next') }}</a>
        </li>
    </ul>
</nav>
<p class="text-center text-body-secondary">{{ pagination_first }} – {{ pagination_last }} {{ _('of') }} {{ total }}</p>
{% endif %}
{% else %}
<p>{{ _('No activities match the filter.') }}</p>
{% endif %}

{% endblock %}

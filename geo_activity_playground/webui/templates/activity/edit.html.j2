{% extends "page.html.j2" %}

{% block container %}

<h1 class="mb-3">{{ _('Edit Activity') }}</h1>

<form method="POST">
    <div class="mb-3">
        <label for="name" class="form-label">{{ _('Name') }}</label>
        <input type="text" class="form-control" id="name" name="name" value="{{ activity.name }}" />
    </div>

    <div class="mb-3">
        <label for="kind" class="form-label">{{ _('Kind') }}</label>
        <select class="form-control" id="kind" name="kind">
            {% for kind in kinds %}
            <option value="{{ kind.id }}" {% if activity.kind==kind or (activity.kind==None and kind.name=="Unknown") %} selected {% endif %}>{{ kind.name }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="mb-3">
        <label for="equipment" class="form-label">{{ _('Equipment') }}</label>
        <select class="form-control" id="equipment" name="equipment">
            {% for equipment in equipments %}
            <option value="{{ equipment.id }}" {% if activity.equipment==equipment or (activity.equipment==None and equipment.name=="Unknown") %} selected {% endif %}>
                {{ equipment.name }}
            </option>
            {% endfor %}
        </select>
    </div>

    <div class="mb-3">
        <label for="" class="form-label">{{ _('Tags') }}</label>
        <div class="form-control">
            {% for tag in tags %}
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="tag" value="{{ tag.id }}" id="tag_{{ tag.id }}" {%
                    if tag in activity.tags %} checked {% endif %}>
                <label class="form-check-label" for="tag_{{ tag.id }}">
                    {{ tag.tag }}
                </label>
            </div>
            {% endfor %}
        </div>
    </div>

    <button type="submit" class="btn btn-primary">{{ _('Save') }}</button>
</form>

{% endblock %}
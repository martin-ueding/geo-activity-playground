{% extends "page.html.j2" %}

{% block container %}

<div class="row mb-3">
    <div class="col">
        <h1>{{ _('All Activity Lines') }}</h1>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-12">
        <div id="activity-lines-map" style="height: 500px;"></div>
        <script type="module">
            import { add_layers_to_map } from '/static/map-layers.js';

            function onEachFeature(feature, layer) {
                layer.bindPopup(`<a href=/activity/${feature.properties.activity_id}>${feature.properties.activity_name}</a>`)
            }

            var map = L.map('activity-lines-map', {
                fullscreenControl: true
            });
            add_layers_to_map(map, {
                zoom: {{ explorer_zoom_levels[0] }},
                zoomLevels: {{ explorer_zoom_levels | tojson }},
                attribution: '{{ map_tile_attribution|safe }}',
                baseLayer: 'Grayscale',
                overlay: null
            });

            let geojson = L.geoJSON({{ geojson| safe }}, {
                style: function (feature) { return { color: feature.properties.color } },
                onEachFeature: onEachFeature
            }).addTo(map)
            map.fitBounds(geojson.getBounds());
        </script>
    </div>
</div>

{% endblock %}
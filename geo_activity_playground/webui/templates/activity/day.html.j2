{% extends "page.html.j2" %}

{% block container %}
<div class="row mb-3">
    <div class="col">
        <h1>{{ date }}</h1>
    </div>
</div>


<div class="row mb-3">
    <div class="col-12">
        <div id="activity-day-map" style="height: 500px;"></div>
        <script type="module">
            import { add_layers_to_map } from '/static/map-layers.js';

            var map = L.map('activity-day-map', {
                fullscreenControl: true
            });
            add_layers_to_map(map, {
                zoom: {{ explorer_zoom_levels[0] }},
                zoomLevels: {{ explorer_zoom_levels | tojson }},
                attribution: '{{ map_tile_attribution|safe }}',
                baseLayer: 'Grayscale',
                overlay: null
            });

            let geojson = L.geoJSON({{ geojson| safe }}, {
                style: function (feature) { return { color: feature.properties.color } }
            }).addTo(map)
            map.fitBounds(geojson.getBounds());
        </script>
    </div>
</div>

<div class="row mb-3">
    <div class="col">
        <h2>{{ _('Activities') }}</h2>
        <div class="table-responsive">
            <table class="table table-sort table-arrows">
                <thead>
                    <tr>
                        <th>{{ _('Name') }}</th>
                        <th class="d-none d-md-table-cell">{{ _('Date') }}</th>
                        <th>{{ _('Distance / km') }}</th>
                        <th>{{ _('Elapsed time') }}</th>
                        <th>{{ _('Speed / km/h') }}</th>
                        <th class="d-none d-lg-table-cell">{{ _('Equipment') }}</th>
                        <th class="d-none d-lg-table-cell">{{ _('Kind') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for activity in activities %}
                    <tr>
                        <td class="text-break"><span style="color: {{ activity['color'] }};">█</span> <a
                                href="{{ url_for('activity.show', id=activity.id) }}">{{
                                activity.name }}</a></td>
                        <td class="d-none d-md-table-cell">{{ activity.start_local|dt }}</td>
                        <td>{{ activity.distance_km | round(1) }}</td>
                        <td>{{ activity.elapsed_time|td }}</td>
                        <td>{{ activity.average_speed_moving_kmh|round(1) if activity.average_speed_moving_kmh is not none else '—' }}</td>
                        <td class="d-none d-lg-table-cell">{{ activity["equipment"] }}</td>
                        <td class="d-none d-lg-table-cell">{{ activity["kind"] }}</td>
                    </tr>
                    {% endfor %}
                    {% if activities|length > 1 %}
                    <tr>
                        <td><b>{{ _('Total') }}</b></td>
                        <td class="d-none d-md-table-cell"></td>
                        <td><b>{{ total_distance | round(1) }}</b></td>
                        <td><b>{{ total_elapsed_time|td }}</b></td>
                        <td></td>
                        <td class="d-none d-lg-table-cell"></td>
                        <td class="d-none d-lg-table-cell"></td>
                    </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<h2>{{ _('Share picture') }}</h2>

<p><img class="img-fluid sharepic-preview" src="{{ url_for('.day_sharepic', year=year, month=month, day=day) }}" /></p>

{% endblock %}
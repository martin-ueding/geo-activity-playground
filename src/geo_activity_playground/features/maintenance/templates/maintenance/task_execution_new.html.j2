{% extends "page.html.j2" %}

{% block container %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ url_for('equipment.index') }}">{{ _('Equipment') }}</a></li>
        <li class="breadcrumb-item"><a href="{{ url_for('equipment.show', id=task.equipment.id) }}">{{ task.equipment.name }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">{{ _('Mark task done') }}</li>
    </ol>
</nav>

<h1 class="mb-3">{{ _('Mark "%(title)s" as done', title=task.title) }}</h1>

<form method="POST">
    <div class="mb-3">
        <label for="date" class="form-label">{{ _('Date') }}</label>
        <input type="date" class="form-control" id="date" name="date"
            value="{{ defaults.date.strftime('%Y-%m-%d') }}" required />
    </div>

    <div class="mb-3">
        <label for="usage_km" class="form-label">{{ _('Usage / km') }}</label>
        <input type="number" class="form-control" id="usage_km" name="usage_km" value="{{ defaults.usage_km }}" />
    </div>

    <div class="mb-3">
        <label for="comment" class="form-label">{{ _('Comment') }}</label>
        <textarea class="form-control" id="comment" name="comment" rows="2"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">{{ _('Mark as done') }}</button>
    <a href="{{ url_for('equipment.show', id=task.equipment.id) }}" class="btn btn-secondary">{{ _('Cancel') }}</a>
</form>
{% endblock %}

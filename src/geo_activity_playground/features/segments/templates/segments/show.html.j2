{% extends "page.html.j2" %}

{% block container %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ url_for('.index') }}">{{ _('Segments') }}</a></li>
        <li class="breadcrumb-item active" aria-current="page">{{ segment.name }}</li>
    </ol>
</nav>
<h1 class="mb-3">{{ _('Segment') }} {{ segment.name }}</h1>
<form method="post" action="{{ url_for('.rematch', id=segment.id) }}" class="mb-3">
    <button type="submit" class="btn btn-warning"
        onclick="if(!confirm('{{ _('Delete old matches and re-run matching for this segment?') }}')){event.preventDefault()}">
        {{ _('Re-match Segment') }}
    </button>
</form>

<script type="module">
    import { add_layers_to_map } from '/static/map-layers.js';

    function add_map(id, geojson) {
        let map = L.map(id, {
            fullscreenControl: true
        })
        add_layers_to_map(map, {
            zoom: {{ explorer_zoom_levels[0] }},
            zoomLevels: {{ explorer_zoom_levels | tojson }},
            attribution: '{{ map_tile_attribution|safe }}',
            baseLayer: 'Color',
            overlay: null
        })

        return map
    }

    window.add_map = add_map;
</script>

<div id="map-segment" class="mb-3" style=" height: 500px; width: 100%;"></div>
<script>
    const activity_ids = {{ activity_ids }};
    fetch("/segments/line/{{ segment.id }}/line.geojson").then(response => response.json()).then(
        geojson => {
            const map = add_map("map-segment", geojson)


            let geojson_layer = L.geoJSON(geojson, {
                style: { color: "#ff0000", fillOpacity: 0.0 }
            })
            map.fitBounds(geojson_layer.getBounds())

            let promises = [];
            for (let id of activity_ids) {
                promises.push(fetch(`/activity/${id}/line.geojson`).then(response => response.json()).then(geojson => {
                    L.geoJSON(geojson, {
                        style: { color: "#0000ff", fillOpacity: 0.3 }
                    }).addTo(map)
                }))
            }

            Promise.all(promises).then(() => { geojson_layer.addTo(map) })
        }
    )
</script>

{% for name, plot in plots.items() %}
<h2 class="mb-3">{{ name }}</h2>
<div class="mb-3">
    {{ vega_direct(plot) }}
</div>
{% endfor %}

<h2 class="mb-3">{{ _('Matched activities') }}</h2>

<div class="table-responsive mb-3">
    <table class="table table-sort table-arrows">
        <thead>
            <tr>
                <th>{{ _('Date') }}</th>
                <th>{{ _('Activity') }}</th>
                {% if visible['direction'] %}<th>{{ _('Direction') }}</th>{% endif %}
                {% if visible['distance'] %}<th class="numeric-sort">{{ _('Distance / km') }}</th>{% endif %}
                {% if visible['duration'] %}<th>{{ _('Duration') }}</th>{% endif %}
                {% if visible['average_speed'] %}<th class="numeric-sort">{{ _('Avg. Speed / km/h') }}</th>{% endif %}
                {% if visible['average_power'] %}<th class="numeric-sort">{{ _('Avg. Power / W') }}</th>{% endif %}
                {% if visible['equipment'] %}<th>{{ _('Equipment') }}</th>{% endif %}
                {% if visible['kind'] %}<th>{{ _('Kind') }}</th>{% endif %}
            </tr>
        </thead>
        <tbody>
            {% for row in table %}
            <tr>
                <td>{{ row['entry_time']|dt }}</td>
                <td><a href="{{ url_for('activity.show', id=row['activity_id']) }}">{{ row['activity_name'] }}</a></td>
                {% if visible['direction'] %}<td>{{ row['direction'] }}</td>{% endif %}
                {% if visible['distance'] %}<td>{{ row['distance_km'] | round(2) }}</td>{% endif %}
                {% if visible['duration'] %}<td>{{ row['duration']|td }}</td>{% endif %}
                {% if visible['average_speed'] %}<td>{% if row['average_speed_kmh'] is not none %}{{ row['average_speed_kmh'] | round(1) }}{% endif %}</td>{% endif %}
                {% if visible['average_power'] %}<td>{% if row['power_avg'] is not none %}{{ row['power_avg'] | round(0) | int }}{% endif %}</td>{% endif %}
                {% if visible['equipment'] %}<td>{{ row["equipment_name"] }}</td>{% endif %}
                {% if visible['kind'] %}<td>{{ row["kind_name"] }}</td>{% endif %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
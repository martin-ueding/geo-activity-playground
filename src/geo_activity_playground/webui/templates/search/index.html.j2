{% extends "page.html.j2" %}

{% block container %}

<h1 class="row mb-3">{{ _('Activities Overview & Search') }}</h1>

<div class="mb-3">
    {% include "search_form.html.j2" %}
</div>

<p class="mb-2">
    <a href="{{ url_for('search.map_view') }}?{{ base_query_str }}">{{ _('Map view') }}</a>
</p>

<div class="row row-cols-1 row-cols-md-4 g-3 mb-3">
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Activities') }}</div>
                <div class="fs-4 fw-semibold">{{ total }}</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total distance') }}</div>
                <div class="fs-4 fw-semibold">{{ '%.1f'|format(total_distance_km) }} km</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total elevation gain') }}</div>
                <div class="fs-4 fw-semibold">{{ '%.0f'|format(total_elevation_gain_m) }} m</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-body-secondary small">{{ _('Total elapsed time') }}</div>
                <div class="fs-4 fw-semibold">{{ total_elapsed_time|td }}</div>
            </div>
        </div>
    </div>
</div>

<table class="table table-sort table-arrows">
    <thead>
        <tr>
            <th>{{ _('Name') }}</th>
            <th>{{ _('Date') }}</th>
            <th class="numeric-sort">{{ _('Distance') }}</th>
            <th>{{ _('Elapsed time') }}</th>
            <th>{{ _('Speed / km/h') }}</th>
            <th>{{ _('Equipment') }}</th>
            <th>{{ _('Kind') }}</th>
        </tr>
    </thead>
    <tbody>
        {% for index, activity in activities %}
        <tr>
            <td><a href="{{ url_for('activity.show', id=activity['id']) }}">{{ activity['name'] }}</a></td>
            <td>
                {% if activity['start_local'] is defined %}
                {{ activity['start_local']|dt }} {{ activity.iana_timezone }}
                {% endif %}
            </td>
            <td>{{ '%.1f' % activity["distance_km"] }} km</td>
            <td>{{ activity.elapsed_time|td }}</td>
            <td>
                {% if not activity.average_speed_moving_kmh|isna %}
                {{ activity.average_speed_moving_kmh|round(1) }}
                {% endif %}
            </td>
            <td>{{ activity["equipment"] }}</td>
            <td>{{ activity['kind'] }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">{{ _('Hammerhead API') }}</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">{{ _('Hammerhead Connect') }}</h1>

<div class="row mb-3">
    <div class="col-lg-6">
        <p>{{ _('You can connect to the Hammerhead Karoo API so that rides recorded on your Karoo head unit are downloaded automatically.') }}</p>

        <p>{{ _('Hammerhead does not offer a shared OAuth application, so you need to register your own developer account:') }}</p>
        <ol>
            <li>{{ _('Create a developer account at') }} <a href="https://dashboard.hammerhead.io/create" target="_blank">dashboard.hammerhead.io/create</a>.</li>
            <li>{{ _('Enable developer settings for your account, fill in the app name and description, and accept the API Licensing agreement.') }}</li>
            <li>{{ _('Open the API settings tab that appears after accepting the agreement — your client ID and client secret are listed there.') }}</li>
        </ol>

        <p>{{ _('Make sure to set the redirect URI of your Hammerhead OAuth app to this callback URL:') }}</p>
        <p><code>{{ url_for('settings.hammerhead_callback', _external=True) }}</code></p>

        <p>
            {{ _('Status:') }}
            {% if hammerhead_client_code %}
            <span class="badge text-bg-success">{{ _('Connected') }}</span>
            {% else %}
            <span class="badge text-bg-secondary">{{ _('Not connected') }}</span>
            {% endif %}
        </p>

        {% if hammerhead_client_code %}
        <form action="{{ url_for('settings.hammerhead_disconnect') }}" method="POST"
            onsubmit="return confirm('{{ _('Are you sure you want to disconnect from Hammerhead? You will need to re-authorize to sync activities again.') }}');">
            <button type="submit" class="btn btn-outline-danger">{{ _('Disconnect from Hammerhead') }}</button>
        </form>
        {% endif %}
    </div>

    <div class="col-lg-6">
        <form action="" method="POST">
            <div class="mb-3">
                <label for="hammerhead_client_id" class="form-label">{{ _('Client ID') }}</label>
                <input type="text" class="form-control" id="hammerhead_client_id" name="hammerhead_client_id"
                    value="{{ hammerhead_client_id or '' }}" />
            </div>
            <div class="mb-3">
                <label for="hammerhead_client_secret" class="form-label">{{ _('Client Secret') }}</label>
                <input type="text" class="form-control" id="hammerhead_client_secret" name="hammerhead_client_secret"
                    value="{{ hammerhead_client_secret or '' }}" />
            </div>

            <button type="submit" class="btn btn-primary">{{ _('Connect to Hammerhead') }}</button>
        </form>
    </div>
</div>
{% endblock %}

{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">Strava API</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">Strava Connect</h1>

<div class="row mb-3">
    <div class="col-lg-6">
        <p>You can connect to Strava such that it automatically downloads your activities.</p>

        <p>For more information about how to use this feature see <a
                href="https://martin-ueding.github.io/geo-activity-playground/connect-strava-api/" target="_blank">this
                page in the documentation</a> and then fill in
            "client ID" and "client secret" in the form.</p>

        <p>
            Status:
            {% if strava_client_code %}
            <span class="badge text-bg-success">Connected</span>
            {% else %}
            <span class="badge text-bg-secondary">Not connected</span>
            {% endif %}
        </p>

        {% if strava_client_code %}
        <form action="{{ url_for('settings.strava_disconnect') }}" method="POST"
            onsubmit="return confirm('Are you sure you want to disconnect from Strava? You will need to re-authorize to sync activities again.');">
            <button type="submit" class="btn btn-outline-danger">Disconnect from Strava</button>
        </form>
        {% endif %}
    </div>

    <div class="col-lg-6">
        <form action="" method="POST">
            <div class="mb-3">
                <label for="strava_client_id" class="form-label">Client ID</label>
                <input type="text" class="form-control" id="strava_client_id" name="strava_client_id"
                    value="{{ strava_client_id }}" />
            </div>
            <div class="mb-3">
                <label for="strava_client_secret" class="form-label">Client Secret</label>
                <input type="text" class="form-control" id="strava_client_secret" name="strava_client_secret"
                    value="{{ strava_client_secret }}" />
            </div>

            <button type="submit" class="btn btn-primary">Connect to Strava</button>
        </form>
    </div>
</div>

<hr class="my-4">

<div class="row mb-3">
    <div class="col-lg-6">
        <h2 class="h4">Import Strava Archive</h2>
        <p>Download your account archive from <a href="https://www.strava.com/athlete/delete_your_account"
                target="_blank">Strava</a> and upload the ZIP file here.</p>
        <p>The ZIP file will be extracted into <code>Strava Export</code>. Any existing checkout in that location will
            be replaced.</p>
    </div>
    <div class="col-lg-6">
        <form action="{{ url_for('settings.strava_upload') }}" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="strava_checkout_zip" class="form-label">Strava archive ZIP</label>
                <input type="file" class="form-control" id="strava_checkout_zip" name="strava_checkout_zip"
                    accept=".zip,application/zip" required>
            </div>

            <button type="submit" class="btn btn-outline-primary">Upload Archive</button>
        </form>
    </div>
</div>
{% endblock %}
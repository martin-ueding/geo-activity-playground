{% extends "settings/base.html.j2" %}

{% block breadcrumbs %}
<li class="breadcrumb-item active" aria-current="page">Tags</li>
{% endblock %}

{% block settings_content %}
<h1 class="mb-3">Tags</h1>

<p>You can assign tags to activities to organize and filter them. Create and manage your tags below.</p>

{% if tags %}
<ul class="list-group mb-3">
    {% for tag in tags %}
    <li class="list-group-item d-flex justify-content-between align-items-start">
        <div>
            {{ activity_tag(tag) }}
            {% if tag.extraction_regex %}
            <div class="text-muted small mt-1">
                Regex: <tt>{{ tag.extraction_regex }}</tt>
                {% if tag.extraction_destructive %}
                <span class="badge text-bg-warning ms-1">Destructive</span>
                {% endif %}
            </div>
            {% endif %}
        </div>
        <a class="btn btn-sm btn-primary" href="{{ url_for('.tags_edit', id=tag.id) }}">Edit</a>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="text-muted">No tags defined yet.</p>
{% endif %}

<a class="btn btn-primary" href="{{ url_for('.tags_new') }}">New Tag</a>
<form class="d-inline ms-2" method="POST" action="{{ url_for('.tags_scan_existing') }}">
    <button type="submit" class="btn btn-outline-secondary">Scan Existing Activities</button>
</form>
{% endblock %}
